APP_NAME="پشت گل"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://poshtegol.ir
PUBLIC_SITE_NAME=پشت گل
PUBLIC_SITE_TAGLINE="خبر، نتیجه زنده و روایت فارسی فوتبال جهان"
PUBLIC_SITE_DOMAIN=poshtegol.ir
PUBLIC_ADS_ENABLED=true

POSHTEGOL_ADMIN_MOBILE=09120000000
POSHTEGOL_ADMIN_FIRST_NAME=مدیر
POSHTEGOL_ADMIN_LAST_NAME=پشت گل
POSHTEGOL_ADMIN_PASSWORD=Admin@2026

FAMILY_CUP_ADMIN_MOBILE=
FAMILY_CUP_ADMIN_FIRST_NAME=
FAMILY_CUP_ADMIN_LAST_NAME=
FAMILY_CUP_ADMIN_PASSWORD=
FAMILY_CUP_MASTER_INVITE_CODE=FAMILY2026
UNAUTHORIZED_ACCESS_MODE=show_public_homepage
UNAUTHORIZED_REDIRECT_URL=https://poshtegol.ir
CARD_HASH_SECRET=

PAYMENT_DRIVER=zibal
# برای تست زیبال مقدار true بگذارید؛ در این حالت merchant تستی زیبال استفاده می‌شود.
ZIBAL_SANDBOX=false
ZIBAL_MERCHANT_ID=
# مبلغ‌های برنامه تومان هستند؛ چون درگاه ریال می‌خواهد، مقدار ارسالی در ۱۰ ضرب می‌شود.
PAYMENT_AMOUNT_MULTIPLIER=10
GATEWAY_FEE_PERCENT=10
REFERRAL_RATE=3

FOOTBALL_DATA_ENABLED=true
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_TOKEN=
FOOTBALL_DATA_DOWNLOAD_CRESTS=true
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026
FOOTBALL_DATA_SYNC_DURING_LIVE_SECONDS=120
FOOTBALL_DATA_SYNC_NORMAL_MINUTES=180
FOOTBALL_DATA_SYNC_PRE_TOURNAMENT_HOURS=6

APP_LOCALE=fa
APP_FALLBACK_LOCALE=fa
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

NEWS_ENABLED=false
GNEWS_BASE_URL=https://gnews.io/api/v4
GNEWS_API_KEY=
NEWS_QUERY="FIFA World Cup 2026 OR World Cup 2026"
NEWS_LANGUAGE=en
NEWS_COUNTRY=
NEWS_MAX_PER_SYNC=8
NEWS_DOWNLOAD_IMAGES=true
NEWS_SORT_BY=publishedAt
NEWS_IN_FIELDS=title,description
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
NEWS_TRANSLATION_PROVIDER=gemini
MICROSOFT_TRANSLATOR_KEY=
MICROSOFT_TRANSLATOR_REGION=
MICROSOFT_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
